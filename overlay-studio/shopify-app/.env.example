# Same PostgreSQL as backend (Supabase or Railway Postgres — use same DATABASE_URL as backend)
DATABASE_URL="postgresql://..."
#
# Railway 502 / "Application failed to respond": if `npm start` used to run `prisma migrate deploy` and your DB
# has a FAILED row in `_prisma_migrations` (e.g. from the backend app), migrate deploy exits before the HTTP server
# starts. This app no longer runs migrate on boot; OverlaySubmission is created on demand if missing.
# To repair Prisma history later: fix the failed migration in Supabase, then run `npm run migrate:deploy` locally
# with this service's DATABASE_URL, or use `prisma migrate resolve` from the project that owns that migration.

# From Shopify Partner Dashboard (App credentials)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# This Remix app URL (Railway service URL)
APP_URL="https://your-shopify-remix.up.railway.app"
SHOPIFY_APP_URL="https://your-shopify-remix.up.railway.app"

# Optional: post-install redirect to theme editor to activate App Embed
THEME_EXTENSION_ID=""

# Implux dashboard (for "Open Dashboard" link in app). Production: https://admin.implux.io
FRONTEND_URL="https://admin.implux.io"

# After OAuth: sync merchant to Implux backend (same MERCHANT_SYNC_SECRET on backend)
MERCHANT_SYNC_SECRET=""
# Backend base URL (no trailing slash), e.g. https://api.implux.io
IMPLUX_BACKEND_URL="https://api.implux.io"

# Scopes (comma-separated). read_users is required for IMPLUX_DASHBOARD_ALLOWED_EMAILS (Open Campaigns button).
SCOPES="read_products,write_script_tags,read_orders,write_themes,read_themes,read_users"

# Shopify staff emails (comma-separated) that may use "Open Campaigns" to open the Implux admin dashboard.
# Must match the logged-in staff member’s email. Leave unset or empty to hide the button for everyone.
# IMPLUX_DASHBOARD_ALLOWED_EMAILS="admin@implux.io,ops@implux.io"

# --- Zoho SMTP (overlay request emails from the Shopify app) ---
# Zoho Mail: enable IMAP/POP and create an App Password for this mailbox (Account → Security).
# SMTP: smtp.zoho.com port 465 (SSL) or 587 (TLS). EU accounts often use smtp.zoho.eu.
#
# SMTP_FROM = visible From (optional). If unset, defaults to "Implux Requests <SMTP_USER>".
#   Use a mailbox or alias Zoho allows for that account.
#
# Recipients default in app/lib/sendOverlayRequestEmail.server.js; OVERLAY_REQUEST_TO overrides (comma-separated).
#
# Set these on the **Shopify Remix app** service (Railway / host), same place as SHOPIFY_* and APP_URL.
# Never commit real passwords.
#
# Railway: outbound SMTP (ports 25/465/587) is disabled on Free, Trial, and Hobby plans — connections
# time out. Use Railway Pro+ for Zoho SMTP, or host the app where SMTP is allowed, or use an HTTPS
# email API (Resend, SendGrid, etc.) instead. See https://docs.railway.app/reference/outbound-networking
#
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
# SMTP_SECURE="true"   # default true when port is 465; set false for 587 + STARTTLS
SMTP_USER=""
SMTP_PASS=""
# Optional: override nodemailer timeouts if submits hang (defaults are usually fine)
# SMTP_CONNECTION_TIMEOUT_MS="20000"
# SMTP_SOCKET_TIMEOUT_MS="120000"
# SMTP_SEND_DEADLINE_MS="180000"
# SMTP_FROM="Implux Requests <notifications@implux.io>"
# OVERLAY_REQUEST_TO="matth@implux.io,philip.m@implux.io"
