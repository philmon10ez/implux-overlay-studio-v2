# Set in Vercel: Environment Variables (production)
# Production API: https://api.implux.io (no trailing slash)
# Local: VITE_API_URL=http://localhost:3001

VITE_API_URL=https://api.implux.io

# Optional — quick links on Campaigns tab for Shopify dev testing
# Your dev store hostname (no https):
# VITE_SHOPIFY_DEV_STORE=your-store.myshopify.com
# Theme app extension activate ID from Partner Dashboard → app → Extensions (same as THEME_EXTENSION_ID on Railway):
# VITE_SHOPIFY_THEME_EXTENSION_ID=gid://shopify/ThemeAppExtension/123456789
