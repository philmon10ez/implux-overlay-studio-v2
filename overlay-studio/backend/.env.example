# Railway sets PORT automatically. For DB use Supabase (see docs) or Railway Postgres.

# Supabase: Project Settings → Database → Connection string (URI), add ?sslmode=require
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
JWT_SECRET="your-jwt-secret-change-in-production"
# Admin dashboard origin(s) for CORS (comma-separated). On Railway, if unset, https://admin.implux.io is allowed by default.
FRONTEND_URL="https://admin.implux.io"
PORT=3001

# Shopify (for webhook verification and future app)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# App proxy HMAC (storefront proxy requests)
PROXY_HMAC_SECRET=""

# Rakuten Advertising API
RAKUTEN_CLIENT_ID=""
RAKUTEN_CLIENT_SECRET=""
RAKUTEN_PUBLISHER_ID=""
RAKUTEN_SECURITY_TOKEN=""
